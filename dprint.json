{
  "$schema": "https://dprint.dev/schemas/v0.json",
  "incremental": true,
  "oxc": {
    "indentStyle": "space",
    "lineWidth": 100,
    "indentWidth": 2
  },
  "markdown": {},
  "json": {},
  "yaml": {
    "indentWidth": 2
  },
  "exec": {
    "commands": [
      {
        "command": "rustfmt --edition 2024",
        "exts": ["rs"]
      },
      {
        "command": "nixfmt",
        "exts": ["nix"]
      },
      {
        "command": "taplo format --config .taplo.toml --stdin-filepath {{file_path}} -",
        "exts": ["toml"]
      },
      {
        "command": "shfmt --filename {{file_path}} -i 0",
        "exts": ["sh", "bash"]
      },
      {
        "command": "dartfmt {{file_path}}",
        "exts": ["dart"]
      }
    ]
  },
  "excludes": [
    "target",
    "docs/node_modules",
    "docs/.astro",
    "Cargo.lock",
    "pnpm-lock.yaml",
    "**/pubspec.lock",
    "**/.dart_tool/**",
    "packages/monosecret/coverage",
    ".claude/settings.local.json",
    "context.md",
    "PR-CHANGES.md"
  ],
  "plugins": [
    "https://plugins.dprint.dev/markdown-0.18.0.wasm",
    "https://plugins.dprint.dev/json-0.20.0.wasm",
    "https://plugins.dprint.dev/g-plane/pretty_yaml-v0.5.0.wasm",
    "https://plugins.dprint.dev/exec-0.5.1.json@492414e39dea4dccc07b4af796d2f4efdb89e84bae2bd4e1e924c0cc050855bf",
    "https://plugins.dprint.dev/oxc-0.28.0.wasm"
  ]
}
